// Prisma schema for NULL
// Acceptance criteria (Step 1):
// - Core models and enums are defined for User, Plan, Page, PageVersion, LiveSession, Event, GhostTrace, Report, Upvote, ReportAbuse, AdminUser.
// - Schema supports live/expired workflow and base moderation fields.
//
// Step 7 (Abuse & Admin) extensions (PART 1):
// - Report handling metadata (admin action, handled_by, handled_at)
// - Page moderation metadata (hidden/forced-expire)
// - AdminSession for secure admin auth
// - IpBlock to support simple abuse mitigation
//
// IMPORTANT:


datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum PlanTier {
  free
  standard
  pro
  enterprise
}

enum PageStatus {
  draft
  live
  expired
}

enum EventType {
  enter
  leave
  move
  click
  scroll
  error
  custom
}

enum ReportStatus {
  open
  resolved
  dismissed
}

enum ReportAction {
  none
  hide_page
  force_expire
  suspend_owner
  ban_ip
}

enum AdminRole {
  owner
  staff
  viewer
}

model Plan {
  id          PlanTier @id
  name        String
  price_cents Int?
  features    Json
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  users       User[]
}

model User {
  id           String   @id @default(cuid())
  anon_id      String   @unique
  email        String?  @unique
  password_hash String?
  email_verified_at DateTime?
  last_login_at DateTime?
  plan_id      PlanTier @default(free)
  plan         Plan     @relation(fields: [plan_id], references: [id])
  is_suspended Boolean  @default(false)
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
  pages        Page[]
  sessions     LiveSession[]
  upvotes      Upvote[]
  reports      Report[]
  comments     Comment[]
}

model Page {
  id                  String       @id @default(cuid())
  owner_id            String
  owner               User         @relation(fields: [owner_id], references: [id])
  title               String?
  anon_number         Int
  status              PageStatus   @default(draft)
  live_started_at     DateTime?
  live_expires_at     DateTime?
  deployed_at         DateTime?
  scheduled_report_enabled Boolean @default(false)
  auto_drop_alert      Boolean    @default(false)
  discord_webhook_url  String?
  snapshot_thumbnail  String?
  constraints_version String       @default("v1")
  current_version_id  String?      @unique
  current_version     PageVersion? @relation("CurrentPageVersion", fields: [current_version_id], references: [id])
  collab_invite_code  String?      @unique
  collab_invite_enabled Boolean    @default(false)
  collab_invite_updated_at DateTime?

  // Aggregated metrics (lightweight)
  total_visits      Int   @default(0)
  unique_sessions   Int   @default(0)
  total_clicks      Int   @default(0)
  total_duration_ms Int   @default(0)
  avg_duration_ms   Float @default(0)
  bounce_count      Int   @default(0)
  bounce_rate       Float @default(0)
  upvote_count      Int   @default(0)
  report_count      Int   @default(0)
  abuse_score       Float @default(0)

  // Moderation
  is_hidden  Boolean @default(false)
  is_deleted Boolean @default(false)

  hidden_at           DateTime?
  hidden_reason       String?
  hidden_by_admin_id  String?
  hidden_by_admin     AdminUser? @relation("PageHiddenBy", fields: [hidden_by_admin_id], references: [id])

  forced_expired_at   DateTime?
  forced_by_admin_id  String?
  forced_by_admin     AdminUser? @relation("PageForcedBy", fields: [forced_by_admin_id], references: [id])

  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  versions     PageVersion[] @relation("PageVersions")
  sessions     LiveSession[]
  events       Event[]
  upvotes      Upvote[]
  reports      Report[]
  ghost_traces GhostTrace[]
  comments     Comment[]
  app_collections AppCollection[]
  app_records    AppRecord[]
  daily_stats   DailyPageStats[]
  segments      Segment[]

  app_sessions    AppSession[]
  app_users       AppUser[]
  app_secrets     AppSecret[]
  app_workflows   AppWorkflow[]

  chat_messages   ChatMessage[]
  todos           Todo[]
  calendar_events CalendarEvent[]
  kanban_columns  KanbanColumn[]
  kanban_cards    KanbanCard[]
  note            Note?
  page_settings   PageSetting[]
  page_domains    PageDomain[]
  page_notifications PageNotification[]
  call_states      CallState[]

  @@index([owner_id, status])
  @@index([status, live_expires_at])
}

model Comment {
  id         String    @id @default(cuid())
  page_id    String
  page       Page      @relation(fields: [page_id], references: [id], onDelete: Cascade)
  node_id    String?
  user_id    String
  user       User      @relation(fields: [user_id], references: [id])
  x          Float
  y          Float
  content    String
  parent_id  String?
  parent     Comment?  @relation("CommentReplies", fields: [parent_id], references: [id], onDelete: Cascade)
  replies    Comment[] @relation("CommentReplies")
  resolved   Boolean   @default(false)
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@index([page_id])
  @@index([page_id, node_id])
  @@index([page_id, resolved])
  @@index([parent_id])
}

model PageVersion {
  id          String   @id @default(cuid())
  page_id     String
  page        Page     @relation("PageVersions", fields: [page_id], references: [id])
  current_for Page?    @relation("CurrentPageVersion")
  content_json Json
  created_at  DateTime @default(now())

  @@index([page_id, created_at])
}

model LiveSession {
  id          String  @id @default(cuid())
  session_id  String  @unique
  page_id     String
  page        Page    @relation(fields: [page_id], references: [id])
  viewer_id   String?
  viewer      User?   @relation(fields: [viewer_id], references: [id])
  started_at  DateTime @default(now())
  ended_at    DateTime?
  duration_ms Int?
  last_x      Float?
  last_y      Float?
  referrer    String?
  viewport_w  Int?
  viewport_h  Int?
  created_at  DateTime @default(now())
  updated_at  DateTime @updatedAt
  events      Event[]

  @@index([page_id, started_at])
  @@index([page_id, ended_at])
}

model Event {
  id                 String      @id @default(cuid())
  event_id           String?     @unique
  page_id            String
  page               Page        @relation(fields: [page_id], references: [id])
  live_session_id    String
  live_session       LiveSession @relation(fields: [live_session_id], references: [id])
  ts                 DateTime    @default(now())
  type               EventType
  x                  Float?
  y                  Float?
  element_id         String?
  element_type       String?
  element_label_hash String?
  payload            Json?

  @@index([page_id, ts])
  @@index([page_id, type, ts])
  @@index([live_session_id, ts])
  @@index([page_id, live_session_id, type])
}

model DailyPageStats {
  id        String   @id @default(cuid())
  page_id   String
  page      Page     @relation(fields: [page_id], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  visits    Int      @default(0)
  clicks    Int      @default(0)
  created_at DateTime @default(now())

  @@unique([page_id, date])
  @@index([page_id])
}

model Segment {
  id         String   @id @default(cuid())
  page_id    String
  page       Page     @relation(fields: [page_id], references: [id], onDelete: Cascade)
  name       String
  conditions Json     // { op: "and"|"or", rules: [{ type, value, not?: boolean }] }
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([page_id])
}

model GhostTrace {
  id           String       @id @default(cuid())
  page_id      String
  page         Page         @relation(fields: [page_id], references: [id])
  trace_id     String
  score        Float
  duration_ms  Int
  clicks_count Int
  points_count Int
  clicks       Json?
  created_at   DateTime     @default(now())
  updated_at   DateTime     @updatedAt
  points       GhostPoint[]

  @@index([page_id, score])
}

model GhostPoint {
  id             String     @id @default(cuid())
  ghost_trace_id String
  ghost_trace    GhostTrace  @relation(fields: [ghost_trace_id], references: [id], onDelete: Cascade)
  seq            Int
  t              Float
  x              Float
  y              Float
  created_at     DateTime   @default(now())

  @@index([ghost_trace_id, seq])
}

model Upvote {
  id         String   @id @default(cuid())
  page_id    String
  page       Page     @relation(fields: [page_id], references: [id])
  user_id    String?
  user       User?    @relation(fields: [user_id], references: [id])
  ip_hash    String
  created_at DateTime @default(now())

  @@unique([page_id, ip_hash])
  @@index([page_id, created_at])
}

model Report {
  id         String       @id @default(cuid())
  page_id    String
  page       Page         @relation(fields: [page_id], references: [id])
  user_id    String?
  user       User?        @relation(fields: [user_id], references: [id])
  reason     String?
  status     ReportStatus @default(open)

  // Step 7 handling metadata
  action              ReportAction @default(none)
  admin_note          String?
  handled_at          DateTime?
  handled_by_admin_id String?
  handled_by_admin    AdminUser?   @relation("ReportHandledBy", fields: [handled_by_admin_id], references: [id])

  created_at DateTime @default(now())
  abuses     ReportAbuse[]

  @@index([page_id, status])
  @@index([status, created_at])
}

model ReportAbuse {
  id         String   @id @default(cuid())
  report_id  String
  report     Report   @relation(fields: [report_id], references: [id])
  ip_hash    String
  created_at DateTime @default(now())

  @@index([ip_hash])
  @@index([report_id, created_at])
}

model AdminUser {
  id            String    @id @default(cuid())
  username      String    @unique
  password_hash String
  otp_secret    String?
  role          AdminRole @default(owner)
  is_active     Boolean   @default(true)
  created_at    DateTime  @default(now())
  updated_at    DateTime  @updatedAt

  sessions        AdminSession[]
  handled_reports Report[]      @relation("ReportHandledBy")
  hidden_pages    Page[]        @relation("PageHiddenBy")
  forced_pages    Page[]        @relation("PageForcedBy")
  ip_blocks       IpBlock[]
  audit_logs      AdminAuditLog[] @relation("AdminAuditLogAdmin")
}

model AdminSession {
  id          String   @id @default(cuid())
  admin_id    String
  admin       AdminUser @relation(fields: [admin_id], references: [id])
  token_hash  String   @unique
  ip_hash     String?
  created_at  DateTime @default(now())
  last_seen_at DateTime @default(now())
  expires_at  DateTime

  @@index([admin_id, expires_at])
}

model AdminAuditLog {
  id          String    @id @default(cuid())
  admin_id    String?
  admin       AdminUser? @relation("AdminAuditLogAdmin", fields: [admin_id], references: [id])
  action      String
  target_type String?
  target_id   String?
  ip_hash     String?
  user_agent  String?
  meta        Json?
  created_at  DateTime  @default(now())

  @@index([admin_id, created_at])
  @@index([action, created_at])
}

model IpBlock {
  id                 String   @id @default(cuid())
  ip_hash            String   @unique
  reason             String?
  created_by_admin_id String?
  created_by_admin   AdminUser? @relation(fields: [created_by_admin_id], references: [id])
  created_at         DateTime @default(now())
  expires_at         DateTime?

  @@index([expires_at])
}

model SystemSetting {
  key        String   @id
  value      Json
  updated_at DateTime @updatedAt
}

model AppCollection {
  id        String   @id @default(cuid())
  page_id   String
  page      Page     @relation(fields: [page_id], references: [id], onDelete: Cascade)
  slug      String
  name      String
  strict    Boolean  @default(false)
  fields    Json     // [{ name, type: string|number|boolean|date|json|relation, required?: boolean }]
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
  records   AppRecord[]  // AppRecord.collection_slug = slug

  @@unique([page_id, slug])
  @@index([page_id])
}

model AppRecord {
  id              String   @id @default(cuid())
  page_id         String
  page            Page     @relation(fields: [page_id], references: [id], onDelete: Cascade)
  collection_slug String
  data            Json
  updated_at      DateTime @updatedAt
  collection      AppCollection @relation(fields: [page_id, collection_slug], references: [page_id, slug], onDelete: Cascade)

  @@index([page_id, collection_slug])
  @@index([page_id])
}

model AppUser {
  id            String   @id @default(cuid())
  page_id       String
  page          Page     @relation(fields: [page_id], references: [id], onDelete: Cascade)
  email         String
  password_hash String
  display_name  String?
  avatar_url    String?
  role          String   @default("user")
  metadata      Json?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  sessions      AppSession[]

  @@unique([page_id, email])
  @@index([page_id])
}

model AppSession {
  id          String   @id @default(cuid())
  page_id     String
  page        Page     @relation(fields: [page_id], references: [id], onDelete: Cascade)
  app_user_id String
  app_user    AppUser  @relation(fields: [app_user_id], references: [id], onDelete: Cascade)
  token       String   @unique
  expires_at  DateTime
  created_at  DateTime @default(now())

  @@index([token])
  @@index([app_user_id])
}

model AppSecret {
  id        String   @id @default(cuid())
  page_id   String
  page      Page     @relation(fields: [page_id], references: [id], onDelete: Cascade)
  key       String
  value     String
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@unique([page_id, key])
  @@index([page_id])
}

model AppWorkflow {
  id         String   @id @default(cuid())
  page_id    String
  page       Page     @relation(fields: [page_id], references: [id], onDelete: Cascade)
  name       String
  trigger    Json     // WorkflowTrigger
  steps      Json     // WorkflowStep[]
  enabled    Boolean  @default(true)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([page_id])
}

model AppWorkflowLog {
  id          String   @id @default(cuid())
  workflow_id String
  page_id     String
  status      String   // "success" | "error" | "running"
  input       Json?
  output      Json?
  error       String?
  started_at  DateTime @default(now())
  finished_at DateTime?

  @@index([workflow_id])
  @@index([page_id])
}

model ChatMessage {
  id             String   @id @default(cuid())
  page_id        String
  page           Page     @relation(fields: [page_id], references: [id], onDelete: Cascade)
  sender_user_id String?
  sender_anon_id String?
  content        String
  created_at     DateTime @default(now())

  @@index([page_id, created_at])
}

model Todo {
  id         String   @id @default(cuid())
  page_id    String
  page       Page     @relation(fields: [page_id], references: [id], onDelete: Cascade)
  title      String
  done       Boolean  @default(false)
  sort_order Int      @default(0)
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt

  @@index([page_id, sort_order])
}

model CalendarEvent {
  id         String    @id @default(cuid())
  page_id    String
  page       Page      @relation(fields: [page_id], references: [id], onDelete: Cascade)
  title      String
  start_at   DateTime
  end_at     DateTime?
  all_day    Boolean   @default(false)
  meta       Json?
  created_at DateTime  @default(now())
  updated_at DateTime  @updatedAt

  @@index([page_id, start_at])
}

model KanbanColumn {
  id         String       @id @default(cuid())
  page_id    String
  page       Page         @relation(fields: [page_id], references: [id], onDelete: Cascade)
  title      String
  sort_order Int          @default(0)
  created_at DateTime     @default(now())
  updated_at DateTime     @updatedAt
  cards      KanbanCard[]

  @@index([page_id, sort_order])
}

model KanbanCard {
  id         String        @id @default(cuid())
  page_id    String
  page       Page          @relation(fields: [page_id], references: [id], onDelete: Cascade)
  column_id  String
  column     KanbanColumn  @relation(fields: [column_id], references: [id], onDelete: Cascade)
  title      String
  body       String?
  sort_order Int           @default(0)
  created_at DateTime      @default(now())
  updated_at DateTime      @updatedAt

  @@index([page_id, column_id, sort_order])
}

model Note {
  id             String   @id @default(cuid())
  page_id        String   @unique
  page           Page     @relation(fields: [page_id], references: [id], onDelete: Cascade)
  author_user_id String?
  author_anon_id String?
  content        String   @default("")
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  @@index([page_id])
}

model PageSetting {
  id        String   @id @default(cuid())
  page_id   String
  page      Page     @relation(fields: [page_id], references: [id], onDelete: Cascade)
  key       String
  value     Json
  updated_at DateTime @default(now()) @updatedAt

  @@unique([page_id, key])
  @@index([page_id])
}

model PageDomain {
  id              String   @id @default(cuid())
  page_id         String
  page            Page     @relation(fields: [page_id], references: [id], onDelete: Cascade)
  domain          String   @unique
  status          String   @default("pending")
  verified_at     DateTime?
  force_https     Boolean  @default(false)
  redirect_www    Boolean  @default(false)
  last_checked_at DateTime?
  last_error      String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  @@index([page_id])
}

model PageNotification {
  id          String    @id @default(cuid())
  page_id     String
  page        Page      @relation(fields: [page_id], references: [id], onDelete: Cascade)
  recipient_user_id String?
  recipient_anon_id String?
  type        String    // mention, comment_reply, chat_mention, etc.
  ref_id      String?   // comment_id, chat_message_id
  title       String?
  body        String?
  read_at     DateTime?
  created_at  DateTime  @default(now())

  @@index([page_id, recipient_user_id, read_at])
  @@index([page_id, recipient_anon_id, read_at])
}

model CallState {
  id           String   @id @default(cuid())
  page_id      String
  page         Page     @relation(fields: [page_id], references: [id], onDelete: Cascade)
  participant_id String  // anon_id or user_id
  status       String   // idle, ringing, in_call, ended
  updated_at   DateTime @default(now()) @updatedAt

  @@unique([page_id, participant_id])
  @@index([page_id])
}


